@model List<PricingPlan>

<section id="pricing" class="pricing-area pt-70 pb-60 fix p-relative">
    <div class="container">
        <div class="row justify-content-center align-items-center">
            <div class="col-lg-6 col-md-12">
                <div class="section-title center-align pr-60" data-aos="fade-up" data-aos-duration="1000">
                    <h2>
                        Esnek Sigorta <br>Paketlerimiz
                    </h2>
                    <p class="pt-30" data-aos="fade-up" data-aos-duration="1200">İhtiyaçlarınıza uygun, bütçenize göre şekillendirilebilen sigorta paketlerimizle sizi ve sevdiklerinizi güvence altına alıyoruz.</p>
                    <p data-aos="fade-up" data-aos-duration="1400">Bireysel ve kurumsal müşterilerimize özel hazırlanmış paketlerimiz, kapsamlı teminatlar ve uygun fiyatlarla hayatınızı kolaylaştırır.</p>
                </div>
            </div>




            <div class="col-lg-6 col-md-12">
               
                    <div class="row">
                        <div class="col-lg-6 col-md-6">
                            <div class="pricing-box pricing-box2 mb-60" data-aos="fade-left" data-aos-duration="1000">
                                <div class="pricing-head">
                                    <h3>Standart</h3>
                                    <div class="price-count">
                                        <h2>299₺ <strong>/Ay</strong></h2>
                                    </div>
                                    <hr>
                                </div>
                                <div class="pricing-body mt-20 mb-30 text-left">
                                    <ul>
                                        <li>Temel sağlık teminatı</li>
                                        <li>Kaza sigortası</li>
                                        <li>7/24 müşteri desteği</li>
                                        <li>Dijital poliçe yönetimi</li>
                                        <li>Yıllık ücretsiz danışmanlık</li>
                                    </ul>
                                </div>
                                <div class="pricing-btn">
                                    <a href="contact.html" class="btn ss-btn">Hemen Başla</a>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6 col-md-6">
                            <div class="pricing-box pricing-box2 active mb-60" data-aos="fade-left" data-aos-duration="1400">
                                <div class="pricing-head">
                                    <h3>Premium</h3>
                                    <div class="price-count">
                                        <h2>₺499 <strong>/Ay</strong></h2>
                                    </div>
                                    <hr>
                                </div>
                                <div class="pricing-body mt-20 mb-30 text-left">
                                    <ul>
                                        <li>Kapsamlı sağlık teminatı</li>
                                        <li>Hayat ve kaza sigortası</li>
                                        <li>7/24 öncelikli destek</li>
                                        <li>Dijital poliçe yönetimi</li>
                                        <li>Sınırsız ücretsiz danışmanlık</li>
                                    </ul>
                                </div>
                                <div class="pricing-btn">
                                    <a href="contact.html" class="btn ss-btn">Hemen Başla</a>
                                </div>
                            </div>
                        </div>
                    </div>
                
            </div>
        </div>
    </div>
</section>
