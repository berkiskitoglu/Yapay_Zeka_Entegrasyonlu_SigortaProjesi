@{
    ViewData["Title"] = "CreateAboutWithGrok";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="container mt-5">
    <h2>Groq AI ile Hakkımızda Oluştur</h2>
    <p class="text-muted">Butona basınca AI otomatik oluşturup kaydeder.</p>
    <form method="post" asp-action="CreateAboutWithGrok">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-robot me-1"></i> Oluştur ve Kaydet
        </button>
        <a asp-action="AboutList" class="btn btn-secondary ms-2">Listeye Dön</a>
    </form>
</div>