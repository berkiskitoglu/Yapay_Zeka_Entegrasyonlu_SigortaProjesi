@model Service

@{
    ViewData["Title"] = "UpdateService";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}


<div class="card">
    <div class="card-body">
        <div class="d-flex align-items-center">
            <h5 class="mb-0">Hizmeti Güncelle</h5>
        </div>
        <br />

        <form method="post">
            <input type="hidden" asp-for="ServiceId"/>
            <label>Başlık</label>
            <input type="text" asp-for="Title" class="form-control" />
            <br />
            <label>Açıklama</label>
            <textarea class="form-control" asp-for="Description" rows="3"></textarea>
            <br />
            <label>İkon Url</label>
            <input type="text" asp-for="IconUrl" class="form-control" />
            <br />
            <label>Görsel Url</label>
            <input type="text" asp-for="ImageUrl" class="form-control" />
            <br />
            <button class="btn btn-primary">Hizmeti Ekle</button>
        </form>
    </div>
</div>



